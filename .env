
# API
SERVER_PORT=8080
ENVIRONMENT=development
DEBUG_MODE=false

# PostgreSQL settings
POSTGRES_DB_USER=postgres
POSTGRES_DB_PASSWORD=password
POSTGRES_DB_NAME=cortex_db
POSTGRES_DB_PORT=5432
POSTGRES_DB_SSLMODE=disable
POSTGRES_DB_HOST=localhost

# Pulselive feed
PULSELIVE_BASE_URL=https://content-ecb.pulselive.com/content/ecb/text/EN/
PULSELIVE_TIMEOUT=5

# Article import (seconds)
ARTICLE_PAGE_SIZE=20
ARTICLE_MAX_PAGES=3
ARTICLE_IMPORT_INTERVAL=60
ARTICLE_IMPORT_TIMEOUT=30

# Central management system sync
CENTRAL_BASE_URL=http://central-management-system:8080
CENTRAL_TIMEOUT=5
ARTICLE_SYNC_BATCH_SIZE=50
ARTICLE_SYNC_MAX_ATTEMPTS=5
ARTICLE_SYNC_INTERVAL=120
ARTICLE_SYNC_TIMEOUT=30
