# =============================================================================
# DNSC – un singur fișier pentru toate credentialele (compose + backend)
# =============================================================================
# Compose citește .env din rădăcina proiectului. Backend încarcă același fișier
# (config.go citește din rădăcina proiectului). În Docker, POSTGRES_DB_HOST e
# suprascris la dnsc-postgres (numele serviciului din aceeași rețea).
# =============================================================================

# API
SERVER_PORT=8080
ENVIRONMENT=development
DEBUG_MODE=false

# PostgreSQL (folosit de compose pentru containerul postgres și de backend pentru conexiune)
POSTGRES_DB_USER=postgres
POSTGRES_DB_PASSWORD=changeme
POSTGRES_DB_NAME=dnsc_db
POSTGRES_DB_PORT=5432
POSTGRES_DB_SSLMODE=disable

# Când rulezi backend în Docker, compose setează POSTGRES_DB_HOST=dnsc-postgres.
# Când rulezi backend local (go run), pune aici localhost.
POSTGRES_DB_HOST=dnsc-postgres

# -----------------------------------------------------------------------------
# Domain auto-whitelist scheduler
# -----------------------------------------------------------------------------
DOMAIN_AUTO_WHITELIST_ENABLED=true
DOMAIN_AUTO_WHITELIST_SCHEDULE=0 40 18 * * *
DOMAIN_AUTO_WHITELIST_TIMEZONE=Europe/Bucharest
DOMAIN_INACTIVITY_DAYS=1
DOMAIN_AUTO_WHITELIST_CHANGED_BY=system
DOMAIN_AUTO_WHITELIST_NOTES=Auto-whitelisted by system.
